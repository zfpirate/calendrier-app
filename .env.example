# Environment Variables Example
# Copy this file to .env and customize values

# Bot Configuration
BOT_SHORT_PAUSE_MS=500
BOT_LOGIN_TIMEOUT_MS=20000
BOT_MAX_CHECKBOX_CLICKS=30

# Firebase Configuration
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your-project"}
APP_URL=https://your-app.firebaseapp.com

# Ecole en Ligne Credentials
EEL_USERNAME=your_username
EEL_PASSWORD=your_password

# Admin Configuration
ADMIN_EMAIL=pirson.maxence2009@gmail.com

# Frontend Configuration
NODE_ENV=production

# Performance Optimization
ENABLE_PERFORMANCE_MONITORING=false
MOBILE_OPTIMIZATION_ENABLED=true
ADAPTIVE_REFRESH_ENABLED=true
